<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:converters="using:Editor.Converters"
			 xmlns:vm="using:Editor.ViewModels"
			 x:Class="Editor.Views.ColorPickerControl"
			 x:DataType="vm:ColorPickerViewModel"
			 x:CompileBindings="True">

	<Grid x:Name="InnerGrid" ColumnDefinitions="40,8,*">

		<!-- Swatch button — opens flyout picker -->
		<Button Grid.Column="0"
				Width="36" Height="36"
				Padding="2"
				CornerRadius="4"
				VerticalAlignment="Center">
			<Button.Flyout>
				<Flyout Placement="BottomEdgeAlignedLeft">
					<StackPanel Spacing="2" Margin="8">

						<!-- Preview bar -->
						<Border Height="20" CornerRadius="3"
								Background="{Binding ColorValue, Converter={x:Static converters:ColorToBrushConverter.Instance}}"
								BorderBrush="{DynamicResource EditorBorderMid}" BorderThickness="1"
								Margin="0,0,0,4"/>

						<!-- R -->
						<StackPanel Orientation="Horizontal" Spacing="4">
							<TextBlock Text="R" Foreground="#FF6666" FontWeight="Bold" VerticalAlignment="Center" FontSize="11" Width="12"/>
							<Slider Value="{Binding ColorR, Mode=TwoWay}" Minimum="0" Maximum="255" Width="120" VerticalAlignment="Center"/>
							<NumericUpDown Value="{Binding ColorR, Mode=TwoWay}" Minimum="0" Maximum="255" Increment="1" FormatString="0"
										   ShowButtonSpinner="False" Width="42" MinWidth="0" Height="22" FontSize="11" TextAlignment="Center"/>
						</StackPanel>

						<!-- G -->
						<StackPanel Orientation="Horizontal" Spacing="4">
							<TextBlock Text="G" Foreground="#66CC66" FontWeight="Bold" VerticalAlignment="Center" FontSize="11" Width="12"/>
							<Slider Value="{Binding ColorG, Mode=TwoWay}" Minimum="0" Maximum="255" Width="120" VerticalAlignment="Center"/>
							<NumericUpDown Value="{Binding ColorG, Mode=TwoWay}" Minimum="0" Maximum="255" Increment="1" FormatString="0"
										   ShowButtonSpinner="False" Width="42" MinWidth="0" Height="22" FontSize="11" TextAlignment="Center"/>
						</StackPanel>

						<!-- B -->
						<StackPanel Orientation="Horizontal" Spacing="4">
							<TextBlock Text="B" Foreground="#6699FF" FontWeight="Bold" VerticalAlignment="Center" FontSize="11" Width="12"/>
							<Slider Value="{Binding ColorB, Mode=TwoWay}" Minimum="0" Maximum="255" Width="120" VerticalAlignment="Center"/>
							<NumericUpDown Value="{Binding ColorB, Mode=TwoWay}" Minimum="0" Maximum="255" Increment="1" FormatString="0"
										   ShowButtonSpinner="False" Width="42" MinWidth="0" Height="22" FontSize="11" TextAlignment="Center"/>
						</StackPanel>

					</StackPanel>
				</Flyout>
			</Button.Flyout>

			<Border CornerRadius="2"
					Background="{Binding ColorValue, Converter={x:Static converters:ColorToBrushConverter.Instance}}"
					HorizontalAlignment="Stretch"
					VerticalAlignment="Stretch"/>
		</Button>

		<!-- Hex text input -->
		<TextBox x:Name="HexInput" Grid.Column="2"
				 Text="{Binding ColorString, Mode=TwoWay}"
				 PlaceholderText="#RRGGBB"
				 VerticalAlignment="Center"/>

	</Grid>

</UserControl>
