<Window xmlns="https://github.com/avaloniaui"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		xmlns:views="using:Editor.Views"
		x:Class="Editor.Views.AboutWindow"
		Title="About WalkerSim2"
		Width="420" Height="460"
		CanResize="False"
		WindowStartupLocation="CenterOwner"
		Background="#12121a">

	<Grid RowDefinitions="*,Auto,Auto">
		<!-- VFX background with overlay text. The VFX host itself is added
		     programmatically after the window has rendered once. -->
		<Grid Grid.Row="0" x:Name="VfxGrid">
			<views:CreditsOverlay x:Name="Credits"/>

			<!-- Header info card overlays the canvas. -->
			<StackPanel x:Name="InfoCard" VerticalAlignment="Top" HorizontalAlignment="Center"
						Margin="20,20,20,0">
				<Border Background="#CC080810" CornerRadius="6" Padding="24,12">
					<StackPanel HorizontalAlignment="Center" Spacing="4">
						<TextBlock Text="WalkerSim2"
								   FontSize="28" FontWeight="Bold"
								   Foreground="#00ddff"
								   HorizontalAlignment="Center"
								   FontFamily="Consolas,Courier New,monospace"/>
						<StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="10">
							<TextBlock x:Name="VersionText"
									   FontSize="12"
									   Foreground="#8899bb"
									   FontFamily="Consolas,Courier New,monospace"/>
							<TextBlock x:Name="CommitText"
									   FontSize="12"
									   Foreground="#556688"
									   FontFamily="Consolas,Courier New,monospace"/>
						</StackPanel>
					</StackPanel>
				</Border>
			</StackPanel>
		</Grid>

		<!-- Loading bar between the canvas and the footer. Hidden by
		     code-behind once the VFX reports Ready. -->
		<ProgressBar Grid.Row="1" x:Name="LoadingSpinner"
					 IsIndeterminate="True"
					 Height="3"
					 ToolTip.Tip="Compiling shader..."/>

		<!-- Bottom bar -->
		<Border Grid.Row="2" Background="#0e0e15" Padding="16,10">
			<Grid ColumnDefinitions="*,Auto">
				<TextBlock Grid.Column="0"
						   Text="github.com/ZehMatt/7dtd-WalkerSim2"
						   FontSize="11" Foreground="#4488aa"
						   VerticalAlignment="Center"
						   FontFamily="Consolas,Courier New,monospace"
						   Cursor="Hand"
						   x:Name="GithubLink"
						   PointerPressed="OnGithubLinkClick"/>
				<Button Grid.Column="1" Content="Close" Click="OnCloseClick"
						MinWidth="70" HorizontalContentAlignment="Center"/>
			</Grid>
		</Border>
	</Grid>
</Window>
