<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Editor.Controls.LabelWithHelp"
             x:CompileBindings="True">
    <StackPanel Orientation="Horizontal" Spacing="3" VerticalAlignment="Center">
        <TextBlock x:Name="PART_Label" VerticalAlignment="Center"/>
        <Button x:Name="PART_HelpButton"
                IsVisible="False"
                Padding="0"
                MinWidth="0"
                MinHeight="0"
                Width="14"
                Height="14"
                Background="Transparent"
                BorderThickness="0"
                VerticalAlignment="Center"
                ToolTip.Tip="Open documentation"
                Click="OnHelpClick">
            <PathIcon Width="12" Height="12"
                      Data="M11,18H13V16H11V18M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M12,20C7.59,20 4,16.41 4,12C4,7.59 7.59,4 12,4C16.41,4 20,7.59 20,12C20,16.41 16.41,20 12,20M12,6A4,4 0 0,0 8,10H10A2,2 0 0,1 12,8A2,2 0 0,1 14,10C14,12 11,11.75 11,15H13C13,12.75 16,12.5 16,10A4,4 0 0,0 12,6Z"
                      Foreground="{DynamicResource EditorTextMuted}"/>
        </Button>
    </StackPanel>
</UserControl>
